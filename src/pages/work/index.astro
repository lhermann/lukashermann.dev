---
// src/pages/work/index.astro
import Layout from '../../layouts/Layout.astro'
import WorkExcerpt from '../../components/WorkExcerpt.astro'
import type { Work } from '../../types/Work'

import * as stagetimer from './stagetimer.md'
import * as rundownStudio from './rundown-studio.md'

const featured = [stagetimer, rundownStudio] as unknown as Work[]
---

<Layout
  title="Work of Lukas Hermann - Founder of Stagetimer and Rundown Studio"
  description="Two bootstrapped, profitable products for the event production world"
>
  <section class="space-y-20">
    <header>
      <h1 class="text-5xl font-semibold leading-tight">
        Work
      </h1>
      <p class="text-xl text-neutral-600 mt-4 max-w-2xl">
        Two bootstrapped, profitable products for the event production world.
      </p>
    </header>

    <ul class="space-y-20">
      {featured.map((project) => (
        <li>
          <WorkExcerpt project={project} />
        </li>
      ))}
    </ul>

    <section class="border-t border-neutral-200 pt-10">
      <h2 class="text-2xl font-semibold mb-4">
        Earlier work
      </h2>
      <p class="text-lg text-neutral-600 max-w-[68ch]">
        Before Stagetimer: co-founded <strong>Dashmaster 2k</strong> (dashboards
        for video professionals) and <strong>Missing Links</strong> (6-digit
        share codes). Product Owner of <strong>AIRD</strong> at Seervision AG.
        Earlier frontend, backend, and design work for Laserhub, Ellen4all,
        Joelmedia, and various
        <a href="/writing/print-and-visual-design/" class="link">print/visual design</a>
        commissions.
      </p>
    </section>
  </section>
</Layout>
