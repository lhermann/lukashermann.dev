---
import type { Work } from '../types/Work'
import ArticleTags from './ArticleTags.astro'

export interface Props {
  project: Work
}

const { project } = Astro.props
const { frontmatter } = project

// Get the compiled HTML content
const htmlContent = project.compiledContent()
---

<article class="md:flex items-start gap-10 space-y-8 md:space-y-0">
  <div class="flex-none md:w-80">
    <a href={frontmatter.visit_link} target="_blank" rel="noopener">
      <div class="aspect-[4/3] rounded-lg overflow-hidden border border-neutral-200 shadow-sm">
        <img
          class="w-full h-full object-cover object-top"
          src={frontmatter.thumbnail}
          srcset={`${frontmatter.thumbnail} 600w, ${frontmatter.thumbnail2x} 1200w`}
          alt={frontmatter.title}
          loading="lazy"
        />
      </div>
    </a>
  </div>
  <div class="flex-1">
    <h2 class="text-3xl font-semibold mb-3">
      {frontmatter.title}
    </h2>
    {frontmatter.tags && (
      <ArticleTags
        class="mb-4 text-sm"
        tags={frontmatter.tags}
        tagClass="border border-neutral-300 text-neutral-600"
      />
    )}
    <div class="text-lg text-neutral-600 mb-5 max-w-[68ch]" set:html={htmlContent}></div>
    <p>
      {frontmatter.read_more_link && (
        <a
          class="inline-block rounded font-semibold px-6 py-2 mr-2 bg-amber-600 text-white hover:bg-amber-700 transition-colors"
          href={frontmatter.read_more_link}
        >
          Read More
        </a>
      )}
      {frontmatter.visit_link && (
        <a
          class="inline-block rounded font-semibold px-6 py-2 mr-2 bg-amber-600 text-white hover:bg-amber-700 transition-colors"
          href={frontmatter.visit_link}
          target="_blank"
          rel="noopener"
        >
          Visit {new URL(frontmatter.visit_link).hostname} →
        </a>
      )}
    </p>
  </div>
</article>
